<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="mini_nara">

    <material name="white"><color rgba="1 1 1 1"/></material>
    <material name="orange"><color rgba="1 0.3 0.1 1"/></material>
    <material name="black"><color rgba="0 0 0 1"/></material>
    <material name="green"><color rgba="0 0.5 0 1"/></material>

    <xacro:include filename="lidar.xacro" />
    <xacro:include filename="camera.xacro" />
    <xacro:include filename="jetson_nano.xacro" />

    <xacro:macro name="inertial_box" params="mass x y z *origin">
        <inertial>
            <xacro:insert_block name="origin"/>
            <mass value="${mass}" />
            <inertia ixx="${(1/12) * mass * (y*y+z*z)}" ixy="0.0" ixz="0.0" iyy="${(1/12) * mass * (x*x+z*z)}" iyz="0.0" izz="${(1/12) * mass * (x*x+y*y)}" />
        </inertial>
    </xacro:macro>

    <xacro:macro name="inertial_cylinder" params="mass length radius *origin">
        <inertial>
            <xacro:insert_block name="origin"/>
            <mass value="${mass}" />
            <inertia ixx="${(1/12) * mass * (3*radius*radius + length*length)}" ixy="0.0" ixz="0.0" iyy="${(1/12) * mass * (3*radius*radius + length*length)}" iyz="0.0" izz="${(1/2) * mass * (radius*radius)}" />
        </inertial>
    </xacro:macro>

    <xacro:macro name="inertial_sphere" params="mass radius *origin">
        <inertial>
            <xacro:insert_block name="origin"/>
            <mass value="${mass}" />
            <inertia ixx="${(2/5) * mass * (radius*radius)}" ixy="0.0" ixz="0.0" iyy="${(2/5) * mass * (radius*radius)}" iyz="0.0" izz="${(2/5) * mass * (radius*radius)}" />
        </inertial>
    </xacro:macro>

    <link name="base_link"></link>

    <joint name="chassi_joint" type="fixed">
        <parent link="base_link"/>
        <child link="chassi"/>
        <origin xyz="-0.05 0 0" rpy="0 0 0"/>
    </joint>

    <link name="chassi">
        <visual>
            <origin xyz="0.125 0 0.05" rpy="0 0 0"/>
            <geometry><box size="0.25 0.15 0.10"/></geometry>
            <material name="white"/>
        </visual>
        <collision>
            <origin xyz="0.125 0 0.05" rpy="0 0 0"/>
            <geometry><box size="0.25 0.15 0.10"/></geometry>
        </collision>
        <xacro:inertial_box mass="0.5" x="0.25" y="0.15" z="0.10">
            <origin xyz="0.125 0 0.05" rpy="0 0 0"/>
        </xacro:inertial_box>
    </link>

    <joint name="roda_esquerda_joint" type="continuous">
        <parent link="base_link"/>
        <child link="roda_esquerda"/>
        <origin xyz="0 0.085 0" rpy="-1.5708 0 0"/>
        <axis xyz="0 0 1"/>
    </joint>

    <link name="roda_esquerda">
        <visual><geometry><cylinder radius="0.04" length="0.02"/></geometry><material name="orange"/></visual>
        <collision><geometry><cylinder radius="0.04" length="0.02"/></geometry></collision>
        <xacro:inertial_cylinder mass="0.1" length="0.02" radius="0.04"><origin xyz="0 0 0" rpy="0 0 0"/></xacro:inertial_cylinder>
    </link>

    <joint name="roda_direita_joint" type="continuous">
        <parent link="base_link"/>
        <child link="roda_direita"/>
        <origin xyz="0 -0.085 0" rpy="-1.5708 0 0"/> 
        <axis xyz="0 0 1"/>
    </joint>

    <link name="roda_direita">
        <visual><geometry><cylinder radius="0.04" length="0.02"/></geometry><material name="orange"/></visual>
        <collision><geometry><cylinder radius="0.04" length="0.02"/></geometry></collision>
        <xacro:inertial_cylinder mass="0.1" length="0.02" radius="0.04"><origin xyz="0 0 0" rpy="0 0 0"/></xacro:inertial_cylinder>
    </link>

    <joint name="caster_wheel_joint" type="fixed">
        <parent link="chassi"/> 
        <child link="caster_wheel"/>
        <origin xyz="0.22 0 -0.02" rpy="0 0 0"/> 
    </joint>

    <link name="caster_wheel">
        <visual><geometry><sphere radius="0.02"/></geometry><material name="black"/></visual>
        <collision><geometry><sphere radius="0.02"/></geometry></collision>
        <xacro:inertial_sphere mass="0.1" radius="0.02"><origin xyz="0 0 0" rpy="0 0 0"/></xacro:inertial_sphere>
    </link>

    <xacro:jetson_nano_base parent_link="chassi" xyz="0.08 0 0.10" rpy="0 0 0"/>
    <xacro:lidar parent_link="chassi" xyz="0.20 0 0.10" rpy="0 0 0"/>
    <xacro:camera_sensor parent_link="chassi" xyz="0.25 0 0.05" rpy="0 0 0"/>

    <gazebo reference="caster_wheel">
        <mu1>0.0</mu1>
        <mu2>0.0</mu2>
    </gazebo>

    <gazebo>
        <plugin filename="gz-sim-diff-drive-system" name="gz::sim::systems::DiffDrive">
            <left_joint>roda_esquerda_joint</left_joint>
            <right_joint>roda_direita_joint</right_joint>
            <wheel_separation>0.17</wheel_separation>
            <wheel_radius>0.04</wheel_radius>
            <max_linear_acceleration>1.0</max_linear_acceleration>
            <max_angular_acceleration>2.0</max_angular_acceleration>
            <topic>cmd_vel</topic>
            <odom_topic>odom</odom_topic>
            <frame_id>odom</frame_id>
            <child_frame_id>base_link</child_frame_id>
        </plugin>
    </gazebo>

</robot>